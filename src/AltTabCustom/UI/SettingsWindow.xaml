<Window x:Class="AltTabCustom.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AltTabCustom.UI"
        Title="AltTabCustom — Settings"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="500" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Docked (large screen)">
                <local:ProfileEditorControl x:Name="DockedEditor" Margin="8" />
            </TabItem>
            <TabItem Header="Laptop (small screen)">
                <local:ProfileEditorControl x:Name="LaptopEditor" Margin="8" />
            </TabItem>
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Display switching" FontWeight="Bold" Margin="0,0,0,6" />
                        <CheckBox x:Name="EnableProfilesBox"
                                  Content="Automatically switch profiles based on screen size"
                                  Margin="0,4" />
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       Text="Large-screen width threshold (px)" />
                            <TextBox Grid.Column="1" x:Name="ThresholdBox" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock x:Name="CurrentScreenHint"
                                   Foreground="#666" TextWrapping="Wrap" Margin="0,2,0,0" />
                        <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,8,0,0"
                                   Text="At or above the threshold (effective width of the monitor the switcher opens on) the Docked profile is used; below it, the Laptop profile. Turn the checkbox off to always use the Docked profile." />

                        <TextBlock Text="Behavior" FontWeight="Bold" Margin="0,18,0,6" />
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       Text="Overlay show delay (ms, 0 = instant)" />
                            <TextBox Grid.Column="1" x:Name="ShowDelayBox" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,2,0,6"
                                   Text="A quick Alt+Tab tap within this delay switches straight to your last window without showing the overlay." />
                        <CheckBox x:Name="StartWithWindowsBox" Content="Start with Windows (per-user, no admin)" Margin="0,4" />
                        <CheckBox x:Name="PreventAltMenuBox" Content="Prevent Alt menu pop on release" Margin="0,4" />
                        <CheckBox x:Name="ClickToActivateBox" Content="Click an item to activate it" Margin="0,4" />
                        <CheckBox x:Name="AcrylicBox" Content="Acrylic (blurred) background — experimental" Margin="0,4" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Icon rules">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,8"
                               Text="Force a custom icon for windows whose title or process name matches. Rules are checked top to bottom; the first match wins. Point each rule at a .ico or .png file." />

                    <ListBox Grid.Row="1" x:Name="RulesList"
                             SelectionChanged="RulesList_SelectionChanged"
                             DisplayMemberPath="Summary" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8">
                        <Button Content="Add rule" Width="90" Click="AddRule_Click" Margin="0,0,8,0" />
                        <Button x:Name="RemoveRuleButton" Content="Remove" Width="90"
                                Click="RemoveRule_Click" IsEnabled="False" />
                    </StackPanel>

                    <Border Grid.Row="3" x:Name="RuleEditor" BorderBrush="#DDD" BorderThickness="1"
                            Padding="10" IsEnabled="False">
                        <StackPanel>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="When" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="FieldCombo" Width="120" SelectionChanged="RuleDetail_Changed">
                                        <ComboBoxItem Content="Title" />
                                        <ComboBoxItem Content="Process name" />
                                    </ComboBox>
                                    <ComboBox x:Name="MatchCombo" Width="130" Margin="8,0,0,0" SelectionChanged="RuleDetail_Changed">
                                        <ComboBoxItem Content="contains" />
                                        <ComboBoxItem Content="equals" />
                                        <ComboBoxItem Content="matches (regex)" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pattern" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="PatternBox" VerticalAlignment="Center"
                                         TextChanged="RuleDetail_Changed" />
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Icon file" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="IconPathBox" VerticalAlignment="Center"
                                         TextChanged="RuleDetail_Changed" />
                                <Button Grid.Column="2" Content="Browse…" Width="80" Margin="8,0,0,0"
                                        Click="BrowseIcon_Click" />
                            </Grid>
                            <CheckBox x:Name="RuleEnabledBox" Content="Enabled" Margin="0,6,0,0"
                                      Click="RuleDetail_Changed" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ResetButton" Content="Reset to defaults" Width="120" Margin="0,0,8,0" Click="Reset_Click" />
            <Button x:Name="SaveButton" Content="Save" Width="90" Margin="0,0,8,0" Click="Save_Click" IsDefault="True" />
            <Button x:Name="CancelButton" Content="Close" Width="90" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
