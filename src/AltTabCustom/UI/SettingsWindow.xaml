<Window x:Class="AltTabCustom.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AltTabCustom.UI"
        Title="AltTabCustom — Settings"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="500" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Docked (large screen)">
                <local:ProfileEditorControl x:Name="DockedEditor" Margin="8" />
            </TabItem>
            <TabItem Header="Laptop (small screen)">
                <local:ProfileEditorControl x:Name="LaptopEditor" Margin="8" />
            </TabItem>
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Display switching" FontWeight="Bold" Margin="0,0,0,6" />
                        <CheckBox x:Name="EnableProfilesBox"
                                  Content="Automatically switch profiles based on screen size"
                                  Margin="0,4" />
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       Text="Large-screen width threshold (px)" />
                            <TextBox Grid.Column="1" x:Name="ThresholdBox" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock x:Name="CurrentScreenHint"
                                   Foreground="#666" TextWrapping="Wrap" Margin="0,2,0,0" />
                        <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,8,0,0"
                                   Text="At or above the threshold (effective width of the monitor the switcher opens on) the Docked profile is used; below it, the Laptop profile. Turn the checkbox off to always use the Docked profile." />

                        <TextBlock Text="Behavior" FontWeight="Bold" Margin="0,18,0,6" />
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       Text="Overlay show delay (ms, 0 = instant)" />
                            <TextBox Grid.Column="1" x:Name="ShowDelayBox" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,2,0,6"
                                   Text="A quick Alt+Tab tap within this delay switches straight to your last window without showing the overlay." />
                        <CheckBox x:Name="StartWithWindowsBox" Content="Start with Windows (per-user, no admin)" Margin="0,4" />
                        <CheckBox x:Name="PreventAltMenuBox" Content="Prevent Alt menu pop on release" Margin="0,4" />
                        <CheckBox x:Name="ClickToActivateBox" Content="Click an item to activate it" Margin="0,4" />
                        <CheckBox x:Name="AcrylicBox" Content="Acrylic (blurred) background — experimental" Margin="0,4" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ResetButton" Content="Reset to defaults" Width="120" Margin="0,0,8,0" Click="Reset_Click" />
            <Button x:Name="SaveButton" Content="Save" Width="90" Margin="0,0,8,0" Click="Save_Click" IsDefault="True" />
            <Button x:Name="CancelButton" Content="Close" Width="90" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
