<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- WinForms is enabled only for the system tray NotifyIcon. -->
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <RootNamespace>AltTabCustom</RootNamespace>
    <AssemblyName>AltTabCustom</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <!-- No admin manifest: we run as a normal (asInvoker) user. -->
    <!-- High-DPI is configured in app.manifest; silence the WinForms WFAC010 hint. -->
    <NoWarn>$(NoWarn);WFAC010</NoWarn>
    <Version>1.1.0</Version>
    <Product>AltTabCustom</Product>
    <Description>A customizable, no-admin Alt+Tab window switcher for Windows 11.</Description>
  </PropertyGroup>

  <!-- WPF + WinForms both pull their namespaces (System.Windows.Forms,
       System.Drawing) into the implicit global usings, which collide with WPF's
       System.Windows / System.Windows.Media (Application, Color, KeyEventArgs).
       We only touch WinForms/Drawing via the explicit "Forms." alias and
       fully-qualified names, so drop them from the implicit usings. -->
  <ItemGroup>
    <Using Remove="System.Windows.Forms" />
    <Using Remove="System.Drawing" />
  </ItemGroup>

  <!-- Embed the icon as a WPF resource so it can be loaded at runtime for the
       system tray and window chrome (in addition to being the exe icon). -->
  <ItemGroup>
    <None Remove="Assets\app.ico" />
    <Resource Include="Assets\app.ico" />
  </ItemGroup>

  <!-- Convenient single-file, self-contained publish profile defaults.
       Override on the command line if you prefer framework-dependent. -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>

</Project>
